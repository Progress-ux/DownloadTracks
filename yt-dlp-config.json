{
   "format": "bestaudio/best",
   "outtmpl": "%(title)s.%(ext)s",
   "quiet": true,
   "noprogress": true,
   "extractor_args": {
      "youtube": {
         "player_client": ["web", "android"]
      }
   },
   "postprocessors": [
      {
         "key": "FFmpegExtractAudio",
         "preferredcodec": "mp3",
         "preferredquality": "192"
      }
   ]
}