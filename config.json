{
   "output": "downloads",
   "yt-dlp-config": {
      "format": "bestaudio/best",
      "noplaylist": true,
      "outtmpl": "%(title)s.%(ext)s",
      "quiet": true,
      "noprogress": true,
      "extractor_args": {
         "youtube": {
            "player_client": [
               "web",
               "android"
            ]
         }
      },
      "postprocessors": [
         {
            "key": "FFmpegExtractAudio",
            "preferredcodec": "mp3",
            "preferredquality": "192"
         }
      ]
   }
}